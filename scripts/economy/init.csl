import "core:ao"

// ============================================================================
// Economy Module - Freeze Tag
// ============================================================================

Currency_Type :: enum {
    COINS;
    GEMS;
    TOKENS;
    SHARDS;
    TICKETS;
    ICE_CRYSTALS;
    FROST_ESSENCE;
    RUNE_FRAGMENTS;
    STAR_DUST;
    EVENT_TICKETS;
}

Shop_Item :: struct {
    id: string;
    name: string;
    description: string;
    category: string;
    rarity: string;
    price_currency: Currency_Type;
    price_amount: s64;
    icon: string;
    limited: bool;
    limited_quantity: int;
    sold_count: int;
    seasonal: bool;
    season: string;
    requires_level: int;
    craftable: bool;
    crafting_recipe: [..]Crafting_Ingredient;
}

Crafting_Ingredient :: struct {
    item_id: string;
    quantity: int;
}

Blueprint :: struct {
    id: string;
    name: string;
    description: string;
    target_item: string;
    ingredients: [..]Crafting_Ingredient;
    craft_time: float;
    rarity: string;
}

Bundle :: struct {
    id: string;
    name: string;
    description: string;
    items: [..]string;
    price_currency: Currency_Type;
    price_amount: s64;
    discount: float;
    limited: bool;
    seasonal: bool;
}

// ============================================================================
// Currency Management
// ============================================================================

init_player_economy :: proc(player: Player) {
    Economy.get_or_create_currency(player, "coins", 500);
    Economy.get_or_create_currency(player, "gems", 100);
    Economy.get_or_create_currency(player, "tokens", 5);
    Economy.get_or_create_currency(player, "shards", 0);
    Economy.get_or_create_currency(player, "tickets", 3);
    Economy.get_or_create_currency(player, "ice_crystals", 0);
    Economy.get_or_create_currency(player, "frost_essence", 0);
    Economy.get_or_create_currency(player, "rune_fragments", 0);
    Economy.get_or_create_currency(player, "star_dust", 0);
    Economy.get_or_create_currency(player, "event_tickets", 0);
}

deposit_currency :: proc(player: Player, currency: string, amount: s64) {
    Economy.deposit(player, currency, amount);
}

withdraw_currency :: proc(player: Player, currency: string, amount: s64) -> bool {
    balance := Economy.get_balance(player, currency);
    if balance >= amount {
        Economy.withdraw(player, currency, amount);
        return true;
    }
    return false;
}

get_currency_balance :: proc(player: Player, currency: string) -> s64 {
    return Economy.get_balance(player, currency);
}

// ============================================================================
// Reward Distribution
// ============================================================================

distribute_match_rewards :: proc(winner_team: Team) {
    for p: player_iterator() {
        player := p.(Player);

        base_coins: s64 = 50;
        base_xp: s64 = 100;
        bonus_coins: s64 = 0;
        bonus_xp: s64 = 0;

        // Win bonus
        if player.team == winner_team {
            bonus_coins += 100;
            bonus_xp += 200;
        }

        // Performance bonuses
        bonus_coins += player.tags_this_round.(s64) * 10;
        bonus_xp += player.tags_this_round.(s64) * 20;
        bonus_coins += player.rescues_this_round.(s64) * 15;
        bonus_xp += player.rescues_this_round.(s64) * 30;

        // Streak bonus
        if player.streak_count >= 3 {
            bonus_coins += 50;
            bonus_xp += 100;
        }

        // Score bonus
        score_bonus := (player.score / 10).(s64);
        bonus_coins += score_bonus;
        bonus_xp += score_bonus * 2;

        total_coins := base_coins + bonus_coins;
        total_xp := base_xp + bonus_xp;

        Economy.deposit(player, "coins", total_coins);
        add_xp(player, total_xp);

        // Small gem chance
        if get_random_float(0, 1) < 0.1 {
            gem_amount: s64 = 5;
            Economy.deposit(player, "gems", gem_amount);
            announce("Bonus: +% Gems!", {gem_amount});
        }

        player.save_progression_data();
    }
}

