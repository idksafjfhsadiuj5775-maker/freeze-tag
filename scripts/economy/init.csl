// ============================================================================
// Purchase System
// ============================================================================

purchase_item :: proc(player: Player, item_id: string) -> bool {
    items := get_shop_items();
    for item: items {
        if item.id == item_id {
            if player.level < item.requires_level {
                announce("Need level % to purchase this!", {item.requires_level});
                return false;
            }

            if item.limited && item.sold_count >= item.limited_quantity {
                announce("Item sold out!", {});
                return false;
            }

            currency_name: string;
            switch item.price_currency {
                case .COINS:       currency_name = "coins";
                case .GEMS:        currency_name = "gems";
                case .TOKENS:      currency_name = "tokens";
                case .SHARDS:      currency_name = "shards";
                case .TICKETS:     currency_name = "tickets";
                case .ICE_CRYSTALS: currency_name = "ice_crystals";
                case .FROST_ESSENCE: currency_name = "frost_essence";
                case .RUNE_FRAGMENTS: currency_name = "rune_fragments";
                case .STAR_DUST:   currency_name = "star_dust";
                case .EVENT_TICKETS: currency_name = "event_tickets";
            }

            if !withdraw_currency(player, currency_name, item.price_amount) {
                announce("Not enough %!", {currency_name});
                return false;
            }

            // Add item to player inventory
            player.inventory_items.append(item_id);

            // Track category unlocks
            switch item.category {
                case "skin":  player.unlocked_skins.append(item_id);
                case "trail": player.unlocked_trails.append(item_id);
                case "pet":   player.unlocked_pets.append(item_id);
                case "emote": player.unlocked_emotes.append(item_id);
            }

            announce("Purchased: %!", {item.name});
            return true;
        }
    }
    return false;
}

// ============================================================================
// Crafting System
// ============================================================================

get_all_blueprints :: proc() -> [..]Blueprint {
    return {
        {"bp_skin_jade_dragon", "Jade Dragon Blueprint", "Craft the Jade Dragon skin", "skin_jade_dragon", {{"rune_fragments", 10}, {"frost_essence", 5}, {"star_dust", 20}}, 3600, "legendary"},
        {"bp_pet_bot", "Mini Bot Blueprint", "Craft the Mini Bot pet", "pet_bot", {{"rune_fragments", 5}, {"star_dust", 10}}, 1800, "epic"},
        {"bp_trail_lightning", "Lightning Trail Blueprint", "Craft the Lightning Trail", "trail_lightning", {{"frost_essence", 3}, {"star_dust", 15}}, 1200, "legendary"},
        {"bp_skin_void_walker", "Void Walker Blueprint", "Craft the Void Walker skin", "skin_void_walker", {{"rune_fragments", 15}, {"frost_essence", 10}}, 7200, "legendary"},
        {"bp_emote_confetti", "Confetti Emote Blueprint", "Craft the Confetti emote", "emote_confetti", {{"star_dust", 5}}, 300, "epic"},
    };
}

craft_item :: proc(player: Player, blueprint_id: string) -> bool {
    blueprints := get_all_blueprints();
    for bp: blueprints {
        if bp.id == blueprint_id {
            // Check if player has blueprint
            has_bp := false;
            for b: player.blueprints {
                if b == blueprint_id {
                    has_bp = true;
                    break;
                }
            }
            if !has_bp {
                announce("You don't have this blueprint!", {});
                return false;
            }

            // Check ingredients
            for ing: bp.ingredients {
                if !has_item(player, ing.item_id, ing.quantity) {
                    announce("Missing ingredients!", {});
                    return false;
                }
            }

            // Consume ingredients
            for ing: bp.ingredients {
                remove_items(player, ing.item_id, ing.quantity);
            }

            // Grant item
            player.inventory_items.append(bp.target_item);
            announce("Crafted: %!", {bp.name});

            // Remove blueprint
            for i: 0..<player.blueprints.count {
                if player.blueprints[i] == blueprint_id {
                    player.blueprints.ordered_remove(i);
                    break;
                }
            }

            return true;
        }
    }
    return false;
}

// ============================================================================
// Trading System
// ============================================================================

Trade_Offer :: struct {
    offer_id: string;
    player_id: string;
    offered_item: string;
    requested_item: string;
    offered_currency: string;
    offered_amount: s64;
    requested_currency: string;
    requested_amount: s64;
    expires_at: float;
}

trade_offers: [..]Trade_Offer;

create_trade_offer :: proc(player: Player, offered_item: string, requested_item: string, offered_currency: string, offered_amount: s64, requested_currency: string, requested_amount: s64) -> bool {
    if offered_item != "" && !has_item(player, offered_item, 1) {
        announce("You don't have this item!", {});
        return false;
    }

    offer := Trade_Offer{
        offer_id = format_string("trade_%_%", {player.get_user_id(), ao_get_time()});
        player_id = player.get_user_id();
        offered_item = offered_item;
        requested_item = requested_item;
        offered_currency = offered_currency;
        offered_amount = offered_amount;
        requested_currency = requested_currency;
        requested_amount = requested_amount;
        expires_at = ao_get_time() + 86400;
    };
    trade_offers.append(offer);
    announce("Trade offer created!", {});
    return true;
}

accept_trade :: proc(acceptor: Player, offer_id: string) -> bool {
    for i: 0..<trade_offers.count {
        offer := &trade_offers[i];
        if offer.offer_id == offer_id {
            if offer.expires_at < ao_get_time() {
                announce("Trade offer expired!", {});
                trade_offers.ordered_remove(i);
                return false;
            }

            // Exchange items
            if offer.offered_item != "" {
                remove_items(acceptor, offer.offered_item, 1);
                giver := get_player_by_id(offer.player_id);
                if giver != null {
                    giver.inventory_items.append(offer.offered_item);
                }
            }

            if offer.requested_item != "" {
                remove_items_by_id(offer.player_id, offer.requested_item, 1);
                acceptor.inventory_items.append(offer.requested_item);
            }

            announce("Trade completed!", {});
            trade_offers.ordered_remove(i);
            return true;
        }
    }
    return false;
}

// ============================================================================
// Inventory Helpers
// ============================================================================

has_item :: proc(player: Player, item_id: string, quantity: int) -> bool {
    count := 0;
    for item: player.inventory_items {
        if item == item_id {
            count += 1;
        }
    }
    return count >= quantity;
}

remove_items :: proc(player: Player, item_id: string, quantity: int) {
    removed := 0;
    for i: 0..<player.inventory_items.count {
        if removed >= quantity break;
        if player.inventory_items[i] == item_id {
            player.inventory_items.ordered_remove(i);
            removed += 1;
        }
    }
}

remove_items_by_id :: proc(player_id: string, item_id: string, quantity: int) {
    player := get_player_by_id(player_id);
    if player != null {
        remove_items(player, item_id, quantity);
    }
}

// ============================================================================
// Bundles
// ============================================================================

get_bundles :: proc() -> [..]Bundle {
    return {
        {"bundle_starter", "Starter Pack", "Everything you need to start!", {"skin_frost_guardian", "trail_ice", "emote_wave", "pet_cat"}, .COINS, 5000, 0.5, false, false},
        {"bundle_freezer", "Freezer Bundle", "Best for Freezer mains", {"skin_cyber_freezer", "trail_neon", "emote_freeze"}, .GEMS, 500, 0.3, false, false},
        {"bundle_runner", "Runner Bundle", "Best for Runner mains", {"skin_fire_runner", "trail_rainbow", "emote_dance"}, .GEMS, 450, 0.25, false, false},
        {"bundle_legendary", "Legendary Bundle", "The ultimate collection", {"skin_golden_legend", "trail_lightning", "pet_dragon", "emote_confetti"}, .TOKENS, 200, 0.4, true, false},
        {"bundle_winter", "Winter Bundle", "Seasonal winter collection", {"skin_snowflake", "pet_snowman", "trail_ice", "emote_snowball"}, .GEMS, 300, 0.3, false, true},
        {"bundle_halloween", "Halloween Bundle", "Spooky seasonal collection", {"trail_ghost", "pet_ghost", "emote_freeze"}, .GEMS, 350, 0.3, false, true},
    };
}

purchase_bundle :: proc(player: Player, bundle_id: string) -> bool {
    bundles := get_bundles();
    for bundle: bundles {
        if bundle.id == bundle_id {
            currency_name: string;
            switch bundle.price_currency {
                case .COINS:  currency_name = "coins";
                case .GEMS:   currency_name = "gems";
                case .TOKENS: currency_name = "tokens";
                default:      currency_name = "coins";
            }

            if !withdraw_currency(player, currency_name, bundle.price_amount) {
                announce("Not enough %!", {currency_name});
                return false;
            }

            for item_id: bundle.items {
                player.inventory_items.append(item_id);
            }

            announce("Bundle purchased: %!", {bundle.name});
            return true;
        }
    }
    return false;
}
