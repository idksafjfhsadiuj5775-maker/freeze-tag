SpawnEffect :: class : Effect_Base {
    effect_start :: method() {
        set_duration(0.5);
        if this.player != null && this.player.is_local() {
            sprite := this.entity.get_component(Sprite_Renderer);
            if sprite != null { sprite.color = {0.5, 0.8, 1, 0.5}; }
        }
    }
    effect_end :: method(interrupt: bool) {
        sprite := this.entity.get_component(Sprite_Renderer);
        if sprite != null { sprite.color = {1, 1, 1, 1}; }
    }
}
