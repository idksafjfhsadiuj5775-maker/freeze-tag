SpeedEffect :: class : Effect_Base {
    effect_start :: method() {
        player := this.player.(Player);
        if player != null { player.speed_multiplier = 2.0; }
    }
    effect_end :: method(interrupt: bool) {
        player := this.player.(Player);
        if player != null { player.speed_multiplier = 1.0; }
    }
}
