import "core:ao"
import "game"
import "economy"

// Game wide systems
ao_before_scene_load :: proc() {
    coin_icon := get_asset(Texture_Asset, "$AO/ui/kit/Icons/coin/coin_icon.png");
    gem_icon := get_asset(Texture_Asset, "$AO/ui/kit/Icons/_misc/gem_icon.png");
    Economy.register_currency("coins", coin_icon);
    Economy.register_currency("gems", gem_icon);
}

ao_start :: proc() {
    smooth_game_start();
}

ao_update :: proc(dt: float) {

}

ao_late_update :: proc(dt: float) {

}
