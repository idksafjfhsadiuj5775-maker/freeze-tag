import "core:ao"
import "effects"

// ============================================================================
// Maps Module - Freeze Tag Arenas
// ============================================================================

Map_Data :: struct {
    name: string;
    description: string;
    theme: string;
    difficulty: string;
    hazards: [..]string;
    powerup_spots: [..]v2;
    spawns_freezer: [..]v2;
    spawns_runner: [..]v2;
    bounds: v2;
    has_dynamic_elements: bool;
    day_night_cycle: bool;
    weather_enabled: bool;
    secret_rooms: [..]v2;
    music_track: string;
    ambient_color: v4;
}

Map_Hazard :: struct {
    type: string;
    position: v2;
    radius: float;
    damage: float;
    interval: float;
    timer: float;
    active: bool;
    visual: Entity;
}

Map_Region :: struct {
    name: string;
    bounds_min: v2;
    bounds_max: v2;
    properties: map[string]string;
}

Interactive_Object :: struct {
    name: string;
    position: v2;
    object_type: string;
    is_active: bool;
    cooldown: float;
    cooldown_timer: float;
    visual: Entity;
}

current_map_data: Map_Data;
map_hazards: [..]Map_Hazard;
map_regions: [..]Map_Region;
interactive_objects: [..]Interactive_Object;

// ============================================================================
// Map Definitions
// ============================================================================

