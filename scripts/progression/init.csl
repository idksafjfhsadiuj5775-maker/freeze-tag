import "core:ao"

// ============================================================================
// Progression Module - Freeze Tag
// ============================================================================

Quest :: struct {
    id: string;
    name: string;
    description: string;
    category: string;
    required: int;
    reward_type: string;
    reward_amount: s64;
    xp_reward: s64;
    difficulty: string;
    expires_at: float;
}

Achievement :: struct {
    id: string;
    name: string;
    description: string;
    icon: string;
    reward_type: string;
    reward_amount: s64;
    xp_reward: s64;
    hidden: bool;
    category: string;
}

Milestone :: struct {
    id: string;
    name: string;
    description: string;
    required_value: s64;
    reward_type: string;
    reward_amount: s64;
    xp_reward: s64;
}

Tier :: struct {
    name: string;
    min_level: int;
    color: v4;
    title: string;
}

Title :: struct {
    id: string;
    name: string;
    description: string;
    unlock_condition: string;
    rarity: string;
}

// ============================================================================
// Tier Definitions
// ============================================================================

get_tier_for_level :: proc(level: int) -> Tier {
    if level >= 100 {
        return Tier{"LEGEND", 100, {1, 0.8, 0, 1}, "The Legend"};
    } else if level >= 75 {
        return Tier{"MASTER", 75, {1, 0.5, 0, 1}, "The Master"};
    } else if level >= 50 {
        return Tier{"EXPERT", 50, {0, 1, 0.5, 1}, "The Expert"};
    } else if level >= 30 {
        return Tier{"ADVANCED", 30, {0, 0.8, 1, 1}, "The Advanced"};
    } else if level >= 15 {
        return Tier{"INTERMEDIATE", 15, {0.5, 0.5, 1, 1}, "The Intermediate"};
    } else if level >= 5 {
        return Tier{"NOVICE", 5, {0.5, 1, 0.5, 1}, "The Novice"};
    }
    return Tier{"BEGINNER", 0, {1, 1, 1, 1}, "The Beginner"};
}

