get_all_milestones :: proc() -> [..]Milestone {
    return {
        {"milestone_tags_10", "10 Tags", "Tag 10 players", 10, "coins", 100, 50},
        {"milestone_tags_50", "50 Tags", "Tag 50 players", 50, "coins", 300, 150},
