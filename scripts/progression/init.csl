// ============================================================================
// Quest Generation
// ============================================================================

generate_daily_quests :: proc(player: Player) -> [..]Quest {
    quests: [..]Quest;
    add_quest(&quests, "daily_tag", "Tag 10 Players", "Tag 10 players in any mode", 10, "coins", 200, 100, "easy");
    add_quest(&quests, "daily_rescue", "Rescue 5 Teammates", "Rescue 5 frozen teammates", 5, "coins", 200, 100, "easy");
    add_quest(&quests, "daily_win", "Win 2 Matches", "Win 2 matches in any mode", 2, "gems", 20, 150, "medium");
    add_quest(&quests, "daily_score", "Score 500 Points", "Earn 500 points total", 500, "coins", 300, 150, "medium");
    add_quest(&quests, "daily_powerup", "Collect 10 Powerups", "Collect 10 powerups", 10, "coins", 150, 80, "easy");
    add_quest(&quests, "daily_survive", "Survive 5 Rounds", "Remain unfrozen for 5 full rounds", 5, "gems", 30, 200, "hard");
    return quests;
}

generate_weekly_quests :: proc(player: Player) -> [..]Quest {
    quests: [..]Quest;
    add_quest(&quests, "weekly_tag_100", "Tag 100 Players", "Tag 100 players across any mode", 100, "gems", 150, 500, "medium");
    add_quest(&quests, "weekly_rescue_50", "Rescue 50 Teammates", "Rescue 50 teammates", 50, "gems", 150, 500, "medium");
    add_quest(&quests, "weekly_win_10", "Win 10 Matches", "Win 10 matches", 10, "tokens", 10, 800, "hard");
    add_quest(&quests, "weekly_score_5000", "Score 5,000 Points", "Earn 5,000 points total", 5000, "gems", 300, 1000, "hard");
    add_quest(&quests, "weekly_as_freezer", "Play 20 Rounds as Freezer", "Play 20 rounds as a Freezer", 20, "gems", 200, 500, "medium");
    add_quest(&quests, "weekly_as_runner", "Play 20 Rounds as Runner", "Play 20 rounds as a Runner", 20, "gems", 200, 500, "medium");
    add_quest(&quests, "weekly_streak_3", "3 Win Streak", "Win 3 matches in a row", 3, "tokens", 25, 1000, "legendary");

    // Add 7 random daily quests
    dailies := generate_daily_quests(player);
    for i: 0..<min(7, dailies.count) {
        quests.append(dailies[i]);
        dailies[i].reward_amount *= 3;
        dailies[i].xp_reward *= 3;
    }

    return quests;
}

generate_monthly_quests :: proc(player: Player) -> [..]Quest {
    quests: [..]Quest;
    add_quest(&quests, "monthly_tag_1000", "Tag 1,000 Players", "Tag 1,000 players this month", 1000, "tokens", 100, 5000, "legendary");
    add_quest(&quests, "monthly_rescue_500", "Rescue 500 Teammates", "Rescue 500 teammates this month", 500, "tokens", 100, 5000, "legendary");
    add_quest(&quests, "monthly_win_50", "Win 50 Matches", "Win 50 matches this month", 50, "shards", 50, 3000, "epic");
    add_quest(&quests, "monthly_score_25000", "Score 25,000 Points", "Earn 25,000 points this month", 25000, "tokens", 200, 8000, "legendary");
    add_quest(&quests, "monthly_level_up", "Gain 10 Levels", "Gain 10 levels this month", 10, "gems", 500, 3000, "epic");
    return quests;
}

add_quest :: proc(quests: ref [..]Quest, id: string, name: string, desc: string, required: int, reward_type: string, reward_amount: s64, xp_reward: s64, difficulty: string) {
    quests.append(Quest{
        id = id,
        name = name,
        description = desc,
        required = required,
        reward_type = reward_type,
        reward_amount = reward_amount,
        xp_reward = xp_reward,
        difficulty = difficulty,
    });
}

complete_quest :: proc(player: Player, quest_id: string) {
    for i: 0..<player.daily_quests.count {
        if player.daily_quests[i].id == quest_id {
            q := player.daily_quests[i];
            if q.reward_type == "coins" {
                Economy.deposit(player, "coins", q.reward_amount);
            } else if q.reward_type == "gems" {
                Economy.deposit(player, "gems", q.reward_amount);
            } else if q.reward_type == "tokens" {
                Economy.deposit(player, "tokens", q.reward_amount);
            } else if q.reward_type == "shards" {
                Economy.deposit(player, "shards", q.reward_amount);
            }
            add_xp(player, q.xp_reward);
            announce("Quest completed: %! (+% XP)", {q.name, q.xp_reward});
            player.daily_quests.ordered_remove(i);
            return;
        }
    }
}

check_quest_progress :: proc(player: Player) {
    for q: player.daily_quests {
        progress := player.quest_progress[q.id] != nil ? player.quest_progress[q.id] : 0;
        if progress >= q.required && !is_quest_completed(player, q.id) {
            complete_quest(player, q.id);
        }
    }
}

is_quest_completed :: proc(player: Player, quest_id: string) -> bool {
    for q: player.daily_quests {
        if q.id == quest_id return false;
    }
    return true;
}

