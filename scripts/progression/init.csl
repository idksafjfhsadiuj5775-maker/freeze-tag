        {"milestone_tags_500", "500 Tags", "Tag 500 players", 500, "gems", 200, 500},
        {"milestone_tags_1000", "1,000 Tags", "Tag 1,000 players", 1000, "tokens", 50, 1000},
        {"milestone_rescues_10", "10 Rescues", "Rescue 10 teammates", 10, "coins", 100, 50},
        {"milestone_rescues_50", "50 Rescues", "Rescue 50 teammates", 50, "coins", 300, 150},
        {"milestone_rescues_100", "100 Rescues", "Rescue 100 teammates", 100, "gems", 50, 300},
        {"milestone_rescues_500", "500 Rescues", "Rescue 500 teammates", 500, "gems", 200, 500},
        {"milestone_rescues_1000", "1,000 Rescues", "Rescue 1,000 teammates", 1000, "tokens", 50, 1000},
        {"milestone_wins_10", "10 Wins", "Win 10 matches", 10, "coins", 200, 100},
        {"milestone_wins_50", "50 Wins", "Win 50 matches", 50, "gems", 100, 300},
        {"milestone_wins_100", "100 Wins", "Win 100 matches", 100, "gems", 300, 500},
        {"milestone_wins_500", "500 Wins", "Win 500 matches", 500, "tokens", 100, 1000},
        {"milestone_wins_1000", "1,000 Wins", "Win 1,000 matches", 1000, "shards", 50, 2000},
        {"milestone_matches_100", "100 Matches", "Play 100 matches", 100, "coins", 500, 200},
        {"milestone_matches_500", "500 Matches", "Play 500 matches", 500, "gems", 300, 500},
        {"milestone_matches_1000", "1,000 Matches", "Play 1,000 matches", 1000, "tokens", 100, 1000},
    };
}

check_milestones :: proc(player: Player) {
    milestones := get_all_milestones();
    for m: milestones {
        completed_key := "milestone_completed_" + m.id;
        already := Save.get_bool(player, completed_key, false);

        if !already {
            if m.id starts_with "milestone_tags_" && player.lifetime_tags.(s64) >= m.required_value {
                grant_milestone_reward(player, m);
            } else if m.id starts_with "milestone_rescues_" && player.lifetime_rescues.(s64) >= m.required_value {
                grant_milestone_reward(player, m);
            } else if m.id starts_with "milestone_wins_" && player.lifetime_wins.(s64) >= m.required_value {
                grant_milestone_reward(player, m);
            } else if m.id starts_with "milestone_matches_" && player.lifetime_matches.(s64) >= m.required_value {
                grant_milestone_reward(player, m);
            }
        }
    }
}

grant_milestone_reward :: proc(player: Player, milestone: Milestone) {
    if milestone.reward_type == "coins" {
        Economy.deposit(player, "coins", milestone.reward_amount);
    } else if milestone.reward_type == "gems" {
        Economy.deposit(player, "gems", milestone.reward_amount);
    } else if milestone.reward_type == "tokens" {
        Economy.deposit(player, "tokens", milestone.reward_amount);
    } else if milestone.reward_type == "shards" {
        Economy.deposit(player, "shards", milestone.reward_amount);
    }
    add_xp(player, milestone.xp_reward);

    completed_key := "milestone_completed_" + milestone.id;
    Save.set_bool(player, completed_key, true);
    announce("Milestone reached: %! (+% XP)", {milestone.name, milestone.xp_reward});
}

// ============================================================================
// Rebirth System
// ============================================================================

perform_rebirth :: proc(player: Player) -> bool {
    if player.rebirth_count >= 10 return false;
    if player.level < 100 return false;

    cost := (1000 + player.rebirth_count * 500).(s64);
    if Economy.get_balance(player, "tokens") < cost return false;

    Economy.withdraw(player, "tokens", cost);
    player.rebirth_count += 1;
    player.level = 1;
    player.xp = 0;
    player.prestige_level = 0;

    // Rebirth rewards
    Economy.deposit(player, "gems", (500 + player.rebirth_count * 250).(s64));
    grant_rebirth_title(player);

    announce("REBIRTH! % has been reborn % times!", {player.get_username(), player.rebirth_count});
    return true;
}

grant_rebirth_title :: proc(player: Player) {
    title: string;
    switch player.rebirth_count {
        case 1:  title = "Reborn";
        case 2:  title = "Twice Born";
        case 3:  title = "Thrice Born";
        case 4:  title = "Phoenix";
        case 5:  title = "Immortal";
        case 6:  title = "Eternal";
        case 7:  title = "Transcendent";
        case 8:  title = "Infinite";
        case 9:  title = "Omega";
        case 10: title = "Alpha & Omega";
        default: title = "Reborn";
    }

    if !has_title(player, title) {
        player.unlocked_titles.append(title);
        player.selected_title = title;
        announce("Title unlocked: %!", {title});
    }
}

has_title :: proc(player: Player, title: string) -> bool {
    for t: player.unlocked_titles {
        if t == title return true;
    }
    return false;
}

// ============================================================================
// Mastery System
// ============================================================================

get_mastery_for_level :: proc(level: int) -> string {
    if level >= 100   return "Grandmaster";
    if level >= 50    return "Master";
    if level >= 25    return "Expert";
    if level >= 10    return "Adept";
    if level >= 5     return "Apprentice";
    return "Novice";
}

get_mastery_bonus :: proc(level: int) -> float {
    return 1.0 + float(level) * 0.02;
}
