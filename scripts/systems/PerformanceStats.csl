fps_history: [..]float;
frame_times: [..]float;

record_performance :: proc(dt: float) {
    frame_times.append(dt);
    if frame_times.count > 60 { frame_times.ordered_remove(0); }
    fps := 1.0 / max(dt, 0.0001);
    fps_history.append(fps);
    if fps_history.count > 60 { fps_history.ordered_remove(0); }
}

get_average_fps :: proc() -> float {
    if fps_history.count == 0 return 60;
    sum: float;
    for f: fps_history { sum += f; }
    return sum / fps_history.count.(float);
}
