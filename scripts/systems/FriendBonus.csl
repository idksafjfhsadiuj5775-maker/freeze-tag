get_friend_bonus :: proc(player: Player) -> float {
    count := player.friends_list.count;
    return 1.0 + min(count, 10).(float) * 0.05;
}

apply_friend_bonus_rewards :: proc(player: Player) {
    bonus := get_friend_bonus(player);
    if bonus > 1.0 {
        Economy.deposit(player, "coins", (50 * bonus).(s64));
        add_xp(player, (100 * bonus).(s64));
    }
}
