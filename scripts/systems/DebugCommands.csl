import "core:ao"

is_admin_allowed :: proc(player: Player) -> bool {
    if player.get_username() == "MochiMoch" {
        return true;
    }
    key := format_string("admin_whitelist_%", {player.get_user_id()});
    return Save.get_game_string(key, "") == "1";
}

set_whitelist :: proc(target: Player, enabled: bool) {
    key := format_string("admin_whitelist_%", {target.get_user_id()});
    if enabled {
        Save.set_game_string(key, "1");
    } else {
        Save.set_game_string(key, "");
    }
}

parse_int :: proc(value: string) -> s64 {
    sign: s64 = 1;
    index: int = 0;
    result: s64 = 0;
    if value.count > 0 && value[0] == '-' {
        sign = -1;
        index = 1;
    }
    while index < value.count {
        c := value[index];
        if c >= '0' && c <= '9' {
            result = result * 10 + (c - '0').(s64);
        }
        index += 1;
    }
    return result * sign;
}

command_guard :: proc(player: Player) -> bool {
    if is_admin_allowed(player) {
        return true;
    }
    announce("Admin only.", {});
    return false;
}

admin_start :: proc(player: Player) {
    if !command_guard(player) return;
    start_match();
} @chat_command @any

admin_stop :: proc(player: Player) {
    if !command_guard(player) return;
    stop_match();
} @chat_command @any

