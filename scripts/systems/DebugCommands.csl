    sync_badge_tier(player);
    player.apply_win_cosmetic();
} @chat_command @any

reset_leaderboard :: proc() {
}

admin_whitelist :: proc(player: Player, target: Player) {
    if !command_guard(player) return;
    set_whitelist(target, true);
    announce("% whitelisted %", {player.get_username(), target.get_username()});
} @chat_command @any

admin_unwhitelist :: proc(player: Player, target: Player) {
    if !command_guard(player) return;
    set_whitelist(target, false);
    announce("% removed % from whitelist", {player.get_username(), target.get_username()});
} @chat_command @any

admin_forceshutdownloop :: proc(player: Player) {
    if !command_guard(player) return;
    trigger_shutdown_safety_loop();
} @chat_command @any
