import "core:ao"
import "effects"

// ============================================================================
// Events Module - Freeze Tag
// ============================================================================

Event_Type :: enum {
    HOLIDAY;
    WORLD;
    WEEKEND;
    COMMUNITY;
    BOSS_BATTLE;
    INVASION;
    SEASONAL;
    ANNIVERSARY;
    SURPRISE;
    TOURNAMENT;
}

Game_Event :: struct {
    id: string;
    name: string;
    description: string;
    event_type: Event_Type;
    start_time: float;
    end_time: float;
    is_active: bool;
    requirements: [..]string;
    rewards: [..]Event_Reward;
    special_rules: [..]string;
    theme: string;
    exclusive_items: [..]string;
}

Event_Reward :: struct {
    type: string;
    id: string;
    quantity: int;
    rarity: string;
}

Event_Boss :: struct {
    name: string;
    health: int;
    max_health: int;
    damage: int;
    speed: float;
    abilities: [..]string;
    position: v2;
    phase: int;
    max_phases: int;
    reward_pool: [..]Event_Reward;
}

current_event: Game_Event;
active_boss: Event_Boss;
event_participation: map[string]int;

